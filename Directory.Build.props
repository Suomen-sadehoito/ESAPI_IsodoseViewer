<Project>
	<PropertyGroup>
		<Configurations>Debug;Release</Configurations>
		<AppendPlatformToOutputPath>false</AppendPlatformToOutputPath>

		<OutputPath>$(MSBuildThisFileDirectory)BuildOutput\$(Configuration)\</OutputPath>

		<AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>

		<SatelliteResourceLanguages>en</SatelliteResourceLanguages>
	</PropertyGroup>

	<!-- Suppress the SDK's auto-generated AssemblyInfo for all SDK-style projects.
	     Version/company attributes are supplied by GlobalAssemblyInfo.cs instead. -->
	<PropertyGroup Condition="'$(UsingMicrosoftNETSdk)' == 'true'">
		<GenerateAssemblyInfo>false</GenerateAssemblyInfo>
	</PropertyGroup>

	<PropertyGroup Condition="'$(Configuration)' == 'Release'">
		<DebugType>none</DebugType>
		<DebugSymbols>false</DebugSymbols>
	</PropertyGroup>

	<!-- Inject shared version/company attributes into every SDK-style project except Core,
	     which owns the file. Old-style projects (Esapi, FixtureGenerator) include it via
	     an explicit <Compile> entry in their own .csproj. -->
	<ItemGroup Condition="'$(UsingMicrosoftNETSdk)' == 'true' and '$(MSBuildProjectName)' != 'EQD2Viewer.Core'">
		<Compile Include="$(MSBuildThisFileDirectory)EQD2Viewer.Core\Properties\GlobalAssemblyInfo.cs"
		         Link="Properties\GlobalAssemblyInfo.cs" />
	</ItemGroup>

	<!-- Architectural guardrail: only EQD2Viewer.Esapi (the live ESAPI adapter),
	     EQD2Viewer.Stubs (CI-side stand-ins for Varian binaries), and
	     EQD2Viewer.FixtureGenerator (an ESAPI script that exports JSON fixtures)
	     may reference VMS.TPS.* assemblies. Any future drift fails the build with
	     a pointed error instead of going unnoticed. See
	     docs/clean-architecture-audit.md for the rule itself. -->
	<Target Name="EnforceVmsTpsBoundary" BeforeTargets="ResolveAssemblyReferences">
		<PropertyGroup>
			<_VmsTpsAllowlist>;EQD2Viewer.Esapi;EQD2Viewer.Stubs;EQD2Viewer.FixtureGenerator;</_VmsTpsAllowlist>
		</PropertyGroup>
		<ItemGroup>
			<_VmsTpsRefs Include="@(Reference)" Condition=" $([System.String]::Copy('%(Identity)').StartsWith('VMS.TPS')) " />
		</ItemGroup>
		<Error Condition=" '@(_VmsTpsRefs)' != '' AND !$(_VmsTpsAllowlist.Contains(';$(MSBuildProjectName);')) "
		       Text="Architectural rule violated: project '$(MSBuildProjectName)' references a VMS.TPS.* assembly (@(_VmsTpsRefs)). Only EQD2Viewer.Esapi, EQD2Viewer.Stubs, and EQD2Viewer.FixtureGenerator may reference Varian ESAPI. Move the call sites behind an interface in EQD2Viewer.Core." />
	</Target>

</Project>
