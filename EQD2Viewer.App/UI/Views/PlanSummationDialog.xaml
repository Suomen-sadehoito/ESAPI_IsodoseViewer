<Window x:Class="EQD2Viewer.App.UI.Views.PlanSummationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dose Summation — Research Prototype (not for clinical use)"
        Height="700" Width="1050"
        WindowStartupLocation="CenterOwner"
        Background="#0C0E12" Foreground="#F0F2F5" FontFamily="Segoe UI">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/EQD2Viewer.App;component/UI/Styles/SharedStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 0: Header -->
            <RowDefinition Height="Auto"/>  <!-- 1: Method + α/β -->
            <RowDefinition Height="*"/>     <!-- 2: Plan table -->
            <RowDefinition Height="Auto"/>  <!-- 3: Registration progress -->
            <RowDefinition Height="Auto"/>  <!-- 4: Formula -->
            <RowDefinition Height="Auto"/>  <!-- 5: Debug expander -->
            <RowDefinition Height="Auto"/>  <!-- 6: Action buttons -->
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Dose Summation" FontSize="18" FontWeight="SemiBold" Foreground="#F0F2F5" Margin="0,0,0,6"/>
            <TextBlock TextWrapping="Wrap" Foreground="#9BA3B0" FontSize="11.5" LineHeight="18">
                Configure multi-plan dose summation for re-irradiation assessment.
                Each plan's dose is converted to EQD2 independently using its own fractionation,
                then summed voxel-by-voxel on the reference plan's CT grid.
            </TextBlock>
        </StackPanel>

        <!-- METHOD + α/β -->
        <Border Grid.Row="1" Style="{StaticResource Card}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Method" Foreground="#5C6475" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <RadioButton x:Name="RbEQD2" Content="EQD2 summation" IsChecked="True" Foreground="#F0F2F5" Margin="0,0,16,0" GroupName="SumMethod" FontSize="11" VerticalContentAlignment="Center"
                                 ToolTip="Each plan is converted to EQD2 per voxel (using its own fraction count and the Global α/β below) before being summed."/>
                    <RadioButton x:Name="RbPhysical" Content="Physical dose" Foreground="#9BA3B0" GroupName="SumMethod" FontSize="11" VerticalContentAlignment="Center"
                                 ToolTip="Plans are summed as delivered physical dose, without EQD2 conversion. Use only when all plans share the same fractionation."/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center"
                            ToolTip="α/β ratio used to convert each plan to EQD2 before summation. Typical values: 3 Gy (late-responding OARs), 10 Gy (tumour). Accepts both ',' and '.' as decimal separator.">
                    <TextBlock Text="Global α/β" Foreground="#5C6475" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox x:Name="TbAlphaBeta" Text="3.0" Width="48" Background="#222830" Foreground="#F0F2F5" BorderBrush="#2A3040" Padding="6,3" FontSize="11" VerticalContentAlignment="Center"/>
                    <TextBlock Text=" Gy" Foreground="#5C6475" VerticalAlignment="Center" FontSize="11"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- PLAN TABLE -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0" Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#1A1E26" Padding="14,8" CornerRadius="6,6,0,0" BorderBrush="#2A3040" BorderThickness="0,0,0,1">
                    <TextBlock Foreground="#5C6475" FontSize="10">
                        <Run FontWeight="SemiBold">Include</Run><Run Text=" — select plans  |  "/>
                        <Run FontWeight="SemiBold">Ref</Run><Run Text=" — reference CT grid  |  "/>
                        <Run FontWeight="SemiBold">Fx</Run><Run Text=" — fractions  |  "/>
                        <Run FontWeight="SemiBold">Wt</Run><Run Text=" — weight  |  "/>
                        <Run FontWeight="SemiBold">Registration</Run><Run Text=" — spatial mapping"/>
                    </TextBlock>
                </Border>
                <DataGrid Grid.Row="1" x:Name="PlanGrid" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                          SelectionMode="Single" SelectionUnit="FullRow"
                          Background="#0C0E12" Foreground="#F0F2F5" RowBackground="#12151B" AlternatingRowBackground="#161B22"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#1A1E26" BorderThickness="0" FontSize="11" HeadersVisibility="Column" RowHeight="32">
                    <DataGrid.ColumnHeaderStyle><Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource GridHeader}"/></DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Width="55" Binding="{Binding IsIncluded, UpdateSourceTrigger=PropertyChanged}">
                            <DataGridCheckBoxColumn.Header>
                                <TextBlock Text="Include" ToolTip="Tick to add this plan into the summation."/>
                            </DataGridCheckBoxColumn.Header>
                        </DataGridCheckBoxColumn>
                        <DataGridTemplateColumn Header="Ref" Width="35">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <RadioButton IsChecked="{Binding IsReference, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" GroupName="ReferencePlan" HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Course" Width="75" IsReadOnly="True" Binding="{Binding CourseId}">
                            <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="Foreground" Value="#F0F2F5"/></Style></DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Plan" Width="75" IsReadOnly="True" Binding="{Binding PlanId}">
                            <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="Foreground" Value="#F0F2F5"/></Style></DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Image" Width="65" IsReadOnly="True" Binding="{Binding ImageId}">
                            <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="Foreground" Value="#5C6475"/></Style></DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="FOR" Width="70" IsReadOnly="True" Binding="{Binding ShortFOR}">
                            <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="Foreground" Value="#5C6475"/><Setter Property="FontFamily" Value="Consolas"/><Setter Property="FontSize" Value="9"/><Setter Property="ToolTip" Value="{Binding ImageFOR}"/></Style></DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Dose (Gy)" Width="65" IsReadOnly="True" Binding="{Binding TotalDoseGy, StringFormat=F1}">
                            <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="Foreground" Value="#9BA3B0"/></Style></DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Fx" Width="38" Binding="{Binding NumberOfFractions, UpdateSourceTrigger=PropertyChanged}">
                            <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="Foreground" Value="#F0F2F5"/></Style></DataGridTextColumn.ElementStyle>
                            <DataGridTextColumn.EditingElementStyle><Style TargetType="TextBox"><Setter Property="Background" Value="#222830"/><Setter Property="Foreground" Value="#F0F2F5"/></Style></DataGridTextColumn.EditingElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Wt" Width="38" Binding="{Binding Weight, StringFormat=F1, UpdateSourceTrigger=PropertyChanged}">
                            <DataGridTextColumn.ElementStyle><Style TargetType="TextBlock"><Setter Property="Foreground" Value="#F0F2F5"/></Style></DataGridTextColumn.ElementStyle>
                            <DataGridTextColumn.EditingElementStyle><Style TargetType="TextBox"><Setter Property="Background" Value="#222830"/><Setter Property="Foreground" Value="#F0F2F5"/></Style></DataGridTextColumn.EditingElementStyle>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Header="Registration" Width="170" MinWidth="140">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <TextBlock Text="Reference CT — base grid" Foreground="#4CAF6E" FontSize="10.5" FontStyle="Italic" VerticalAlignment="Center" Padding="6,0">
                                            <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers><DataTrigger Binding="{Binding IsReference}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers>
                                            </Style></TextBlock.Style>
                                        </TextBlock>
                                        <ComboBox ItemsSource="{Binding RelevantRegistrations}" SelectedValue="{Binding SelectedRegistrationId, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Id" DisplayMemberPath="DisplayName">
                                            <ComboBox.Style><Style TargetType="ComboBox" BasedOn="{StaticResource DarkCombo}"><Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers><DataTrigger Binding="{Binding IsReference}" Value="True"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger></Style.Triggers>
                                            </Style></ComboBox.Style>
                                        </ComboBox>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Deformable (DIR)" Width="*" MinWidth="160">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <!-- Reference row: no DIR needed -->
                                        <TextBlock Text="N/A (reference)" Foreground="#3A4050" FontSize="10" FontStyle="Italic" VerticalAlignment="Center" Padding="6,0"
                                                   ToolTip="DIR maps moving plans onto the reference CT grid, so the reference itself has no DIR.">
                                            <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers><DataTrigger Binding="{Binding IsReference}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers>
                                            </Style></TextBlock.Style>
                                        </TextBlock>
                                        <!-- Non-reference row: Calculate button or Status -->
                                        <Grid>
                                            <Grid.Style><Style TargetType="Grid"><Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers><DataTrigger Binding="{Binding IsReference}" Value="True"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger></Style.Triggers>
                                            </Style></Grid.Style>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0">
                                                <TextBlock Text="{Binding DirStatus}" FontSize="10.5" VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#9BA3B0"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasDeformationField}" Value="True">
                                                                    <Setter Property="Foreground" Value="#4CAF6E"/>
                                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>

                                            <Button Grid.Column="1" Content="Calculate DIR"
                                                    Click="CalculateDir_Click"
                                                    Padding="8,2" Margin="2,0,4,0"
                                                    Background="#1A2A3A" Foreground="#4C9EEB"
                                                    BorderBrush="#2A3A5A" FontSize="10.5" Cursor="Hand"
                                                    IsEnabled="{Binding IsDirCalculationEnabled}">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="ToolTip" Value="Run deformable image registration (SimpleITK B-spline) between this plan's CT and the reference CT. Takes 30 s – 3 min depending on volume size."/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCalculating}" Value="True">
                                                                <Setter Property="Content" Value="Calculating..."/>
                                                                <Setter Property="ToolTip" Value="Registration running — click Cancel below to abort."/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsDirCalculationEnabled}" Value="False">
                                                                <Setter Property="ToolTip" Value="DIR module (EQD2Viewer.Registration.ITK.dll) not loaded. Build with the Release-WithITK configuration and deploy SimpleITK DLLs alongside the plugin."/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </Grid>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- PROGRESS (Registration) -->
        <Border Grid.Row="3" Background="#12151B" BorderBrush="#2A3040" BorderThickness="1" CornerRadius="4" Margin="0,0,0,8"
                Visibility="{Binding IsAnyCalculating, Converter={StaticResource BoolToVis}, RelativeSource={RelativeSource AncestorType=Window}}">
            <Grid Margin="12,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="TbRegistrationStatus" Text="Computing deformable registration..." Foreground="#F0F2F5" FontSize="11" Margin="0,0,0,4"/>
                    <ProgressBar x:Name="PbRegistration" Height="4" Minimum="0" Maximum="100" Value="0" Background="#1A1E26" Foreground="#4C9EEB" BorderThickness="0"/>
                </StackPanel>
                <Button Grid.Column="1" Content="Cancel" Click="CancelRegistration_Click" Style="{StaticResource Btn}" Margin="12,0,0,0" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- FORMULA -->
        <Border Grid.Row="4" Style="{StaticResource Card}" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Foreground="#5C6475" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,4">HOW IT WORKS</TextBlock>
                    <TextBlock Foreground="#9BA3B0" FontSize="10.5" TextWrapping="Wrap" LineHeight="16">
                        Each plan's dose is converted to EQD2 voxel-by-voxel, mapped via registration, and summed.
                        DVH is automatically calculated for structures in the reference plan's structure set.
                    </TextBlock>
                </StackPanel>
                <Border Grid.Column="1" Background="#1A1E26" CornerRadius="4" Padding="12,8" Margin="12,0,0,0" VerticalAlignment="Center">
                    <TextBlock Foreground="#4CAF6E" FontSize="10.5" FontFamily="Consolas" TextAlignment="Center">
                        EQD2 = Σᵢ Dᵢ·(dᵢ + α/β)/(2 + α/β)
                    </TextBlock>
                </Border>
            </Grid>
        </Border>

        <!-- DEBUG -->
        <Expander Grid.Row="5" Header="Registration diagnostics" Foreground="#5C6475" FontSize="10" Margin="0,0,0,8" IsExpanded="False">
            <Border Background="#12151B" BorderBrush="#2A3040" BorderThickness="1" CornerRadius="0,0,6,6" Padding="10,8">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <Button Grid.Row="0" Content="Copy debug report to clipboard" Click="CopyDebug_Click" HorizontalAlignment="Left" Padding="8,4" Margin="0,0,0,6"
                            Background="#1A2A3A" Foreground="#4C9EEB" BorderBrush="#2A3A5A" FontSize="10" Cursor="Hand"/>
                    <ScrollViewer Grid.Row="1" MaxHeight="200" VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="TbDebugInfo" Foreground="#9BA3B0" FontSize="9.5" FontFamily="Consolas" TextWrapping="Wrap"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Expander>

        <!-- ACTIONS -->
        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <Button Grid.Column="1" Content="Compute summation" Click="Compute_Click" IsDefault="True" Width="160" Margin="0,0,8,0" FontWeight="SemiBold"
                    ToolTip="Close this dialog and run the voxel-by-voxel summation using the selected plans, registrations, DIRs and α/β.">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAnyCalculating, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                <Setter Property="IsEnabled" Value="False"/>
                                <Setter Property="ToolTip" Value="A DIR registration is running — wait for it to finish before computing the summation."/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Grid.Column="2" Content="Cancel" Style="{StaticResource Btn}" IsCancel="True" Width="80"
                    ToolTip="Discard these settings and close the dialog. No summation is run."/>
        </Grid>
    </Grid>
</Window>
