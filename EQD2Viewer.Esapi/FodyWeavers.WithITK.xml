<Weavers xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="FodyWeavers.xsd">
  <Costura>
    <!-- Release-WithITK: same exclusion list as the default build.
         Registration.ITK + SimpleITK binaries are deployed alongside (not embedded) so that
         AppLauncher's reflection-based loading can detect presence at runtime.
         See Directory.Build.targets :: DeployItkAssembly + OrganizeDeliverables. -->
    <ExcludeAssemblies>
      VMS.TPS.Common.Model.API
      VMS.TPS.Common.Model.Types
      EQD2Viewer.Registration.ITK
      SimpleITKCSharpManaged
    </ExcludeAssemblies>
    <CreateTemporaryAssemblies>true</CreateTemporaryAssemblies>
  </Costura>
</Weavers>
